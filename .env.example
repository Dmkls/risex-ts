# Your account address (the wallet that holds funds)
ACCOUNT_ADDRESS=0x...

# API signer private key (create via RISEx web app → Settings → API Keys)
SIGNER_PRIVATE_KEY=0x...

# Optional: account private key (only needed to register signers programmatically)
# ACCOUNT_PRIVATE_KEY=0x...

# API base URL (default: testnet)
API_URL=https://api.testnet.rise.trade
